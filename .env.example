# OpenCode Zen API (https://opencode.ai/auth)
ZEN_API_KEY=your_zen_api_key
ZEN_BASE_URL=https://opencode.ai/zen/v1
# 무료 모델 5종을 라운드로빈으로 자동 순회 (서킷브레이커 내장)
# big-pickle / minimax-m2.5-free / ling-2.6-flash / hy3-preview-free / nemotron-3-super-free
ZEN_MEMORY_MODEL=big-pickle   # mem0 전용 (싱글톤이므로 별도 고정)

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# NAS 메일 서버 (IMAP)
MAIL_IMAP_HOST=kenca.synology.me
MAIL_IMAP_PORT=993
MAIL_SMTP_HOST=kenca.synology.me
MAIL_SMTP_PORT=465
MAIL_USER=여기에_메일_계정_입력        # 예: user@en-wiki.org
MAIL_PASSWORD=여기에_메일_비밀번호_입력
MAIL_FOLDER=INBOX

# App
APP_ENV=production
DATA_DIR=/app/data
