# OpenCode Zen API (https://opencode.ai/auth)
ZEN_API_KEY=your_zen_api_key
ZEN_BASE_URL=https://opencode.ai/zen/v1
ZEN_MODEL=opencode/big-pickle
ZEN_MEMORY_MODEL=opencode/big-pickle
# 2개 이상 모델 사용 예시:
# ZEN_MODEL=opencode/big-pickle          # 지식처리·할일추출 (무료)
# ZEN_MEMORY_MODEL=opencode/big-pickle   # 메모리 (무료)

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# NAS 메일 서버 (IMAP)
MAIL_IMAP_HOST=kenca.synology.me
MAIL_IMAP_PORT=993
MAIL_SMTP_HOST=kenca.synology.me
MAIL_SMTP_PORT=465
MAIL_USER=여기에_메일_계정_입력        # 예: user@en-wiki.org
MAIL_PASSWORD=여기에_메일_비밀번호_입력
MAIL_FOLDER=INBOX

# App
APP_ENV=production
DATA_DIR=/app/data
