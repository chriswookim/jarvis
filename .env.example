# ── LLM 프로바이더 (설정된 키만 라우팅에 포함됨) ───────────────────

# OpenCode Zen — https://opencode.ai/auth
# 무료 모델 5종: big-pickle, minimax-m2.5-free, ling-2.6-flash, hy3-preview-free, nemotron-3-super-free
ZEN_API_KEY=your_zen_api_key
ZEN_BASE_URL=https://opencode.ai/zen/v1
ZEN_MEMORY_MODEL=big-pickle

# Groq — https://console.groq.com (무료 1K RPM)
# 무료 모델: llama-3.3-70b-versatile, llama-3.1-8b-instant, gemma2-9b-it
GROQ_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey (무료 15 RPM)
# 무료 모델: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-flash-8b
GEMINI_API_KEY=

# OpenRouter — https://openrouter.ai/keys (:free 모델)
# 무료 모델: llama-3.3-70b:free, gemma-3-27b:free, mistral-7b:free
OPENROUTER_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# NAS 메일 서버 (IMAP)
MAIL_IMAP_HOST=kenca.synology.me
MAIL_IMAP_PORT=993
MAIL_SMTP_HOST=kenca.synology.me
MAIL_SMTP_PORT=465
MAIL_USER=여기에_메일_계정_입력        # 예: user@en-wiki.org
MAIL_PASSWORD=여기에_메일_비밀번호_입력
MAIL_FOLDER=INBOX

# App
APP_ENV=production
DATA_DIR=/app/data
